# ========================================
# Environment Variables cho Docker Compose Light
# ========================================
# Copy file này thành .env và cấu hình theo nhu cầu của bạn

# ========================================
# vLLM Model Configuration
# ========================================
# Model name để chạy với vLLM
# Options:
#   - Qwen/Qwen2.5-72B-Instruct (mặc định, mạnh nhất)
#   - meta-llama/Llama-3.3-70B-Instruct (nhẹ hơn, nhanh hơn)
#   - Qwen/QwQ-32B-Preview (reasoning mạnh, context dài)
#   - deepseek-ai/DeepSeek-R1-Distill-Llama-70B (reasoning mạnh)
MODEL_NAME=Qwen/Qwen2.5-72B-Instruct

# ========================================
# Redis Configuration
# ========================================
# Password cho Redis
REDIS_PASSWORD=redispassword

# ========================================
# GPU Configuration (Optional)
# ========================================
# GPU memory utilization (0.0 - 1.0)
GPU_MEMORY_UTILIZATION=0.90

# Max model length (tokens)
MAX_MODEL_LEN=8192

# Tensor parallel size (số GPU)
TENSOR_PARALLEL_SIZE=1